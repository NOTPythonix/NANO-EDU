#!/usr/bin/env python3
"""
Robot control: keyboard (W/A/S/D), camera-based autonomy, optional voice, and IR remote (GPIO 17).
Motor pinout set to user-provided mapping (BCM).
Run: python3 robot_control.py [--mic N]
"""
import argparse
import atexit
import queue
import select
import sys
import termios
import threading
import time
import tty
import cv2
import numpy as np
import RPi.GPIO as GPIO

# Optional voice dependencies
try:
    import speech_recognition as sr
    VOICE_AVAILABLE = True
except Exception:
    VOICE_AVAILABLE = False

# Optional LIRC for IR remote decoding
try:
    import lirc
    LIRC_AVAILABLE = True
except Exception:
    LIRC_AVAILABLE = False

# --- Motor pins (BCM) - user-provided mapping ---
MOTORS = {
    "lf": {"in1": 11,  "in2": 14,  "en": 15},
    "rr": {"in1": 20, "in2": 16, "en": 23},
    "rf": {"in1": 26, "in2": 19, "en": 13},
    "lr": {"in1": 31, "in2": 29, "en": 12},
}

# --- Direction correction (keep previous defaults; adjust if needed) ---
DIR_CORRECT = {
    "lf": True,
    "lr": True,
    "rf": False,
    "rr": False,
}

PWM_FREQ = 1000
DEFAULT_SPEED = 100

# IR receiver GPIO (data pin)
IR_GPIO = 17

# --- Keyboard reader (non-blocking) ---
class KeyReader:
    def __init__(self):
        self.fd = sys.stdin.fileno()
        self.old = termios.tcgetattr(self.fd)
        tty.setcbreak(self.fd)
        atexit.register(self.restore)

    def restore(self):
        try:
            termios.tcsetattr(self.fd, termios.TCSADRAIN, self.old)
        except Exception:
            pass

    def get_key(self):
        r, _, _ = select.select([sys.stdin], [], [], 0)
        if r:
            return sys.stdin.read(1)
        return None

# --- GPIO setup ---
GPIO.setmode(GPIO.BCM)
GPIO.setwarnings(False)
pwms = {}

def setup_motors():
    for name, pins in MOTORS.items():
        GPIO.setup(pins["in1"], GPIO.OUT)
        GPIO.setup(pins["in2"], GPIO.OUT)
        GPIO.setup(pins["en"], GPIO.OUT)
        GPIO.output(pins["in1"], GPIO.LOW)
        GPIO.output(pins["in2"], GPIO.LOW)
        pwm = GPIO.PWM(pins["en"], PWM_FREQ)
        pwm.start(0)
        pwms[name] = pwm

def set_motor_direction(name, forward=True):
    pins = MOTORS[name]
    real_forward = forward if DIR_CORRECT.get(name, True) else not forward
    if real_forward:
        GPIO.output(pins["in1"], GPIO.HIGH)
        GPIO.output(pins["in2"], GPIO.LOW)
    else:
        GPIO.output(pins["in1"], GPIO.LOW)
        GPIO.output(pins["in2"], GPIO.HIGH)

def set_speed(speed):
    s = max(0, min(100, int(speed)))
    for pwm in pwms.values():
        pwm.ChangeDutyCycle(s)

def stop_all():
    for name, pins in MOTORS.items():
        GPIO.output(pins["in1"], GPIO.LOW)
        GPIO.output(pins["in2"], GPIO.LOW)
        pwms[name].ChangeDutyCycle(0)

def cleanup():
    stop_all()
    for pwm in pwms.values():
        pwm.stop()
    GPIO.cleanup()

# --- Movement primitives ---
def forward(speed):
    for m in MOTORS:
        set_motor_direction(m, True)
    set_speed(speed)

def backward(speed):
    for m in MOTORS:
        set_motor_direction(m, False)
    set_speed(speed)

def turn_right(speed):
    for m in ("rf", "lr"):
        set_motor_direction(m, False)
    for m in ("rr", "lf"):
        set_motor_direction(m, True)
    set_speed(speed)

def turn_left(speed):
    for m in ("rf", "lr"):
        set_motor_direction(m, True)
    for m in ("rr", "lf"):
        set_motor_direction(m, False)
    set_speed(speed)

# --- Camera-based obstacle detection ---
def detect_obstacle(frame):
    gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
    blur = cv2.GaussianBlur(gray, (15, 15), 0)
    _, thresh = cv2.threshold(blur, 120, 255, cv2.THRESH_BINARY_INV)
    contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    if not contours:
        return "clear"
    largest = max(contours, key=cv2.contourArea)
    area = cv2.contourArea(largest)
    if area < 6000:
        return "clear"
    x, y, w, h = cv2.boundingRect(largest)
    center_x = x + w // 2
    if center_x < 150:
        return "left"
    elif center_x > 350:
        return "right"
    else:
        return "center"

# --- Voice controller (background, Google Web Speech by default) ---
class VoiceController:
    def __init__(self, command_queue, mic_device_index=None):
        self.command_queue = command_queue
        self.recognizer = None
        self.mic = None
        self.stop_listening = None
        self.mic_device_index = mic_device_index
        if VOICE_AVAILABLE:
            self._setup()

    def _setup(self):
        try:
            self.recognizer = sr.Recognizer()
            if self.mic_device_index is None:
                self.mic = sr.Microphone()
            else:
                self.mic = sr.Microphone(device_index=self.mic_device_index)
            with self.mic as source:
                self.recognizer.adjust_for_ambient_noise(source, duration=1)
        except Exception as e:
            print("VoiceController: microphone setup failed:", e)
            self.mic = None
            self.recognizer = None

    def start(self):
        if not VOICE_AVAILABLE or not self.mic or not self.recognizer:
            return
        self.stop_listening = self.recognizer.listen_in_background(self.mic, self._callback, phrase_time_limit=4)

    def stop(self):
        if self.stop_listening:
            self.stop_listening(wait_for_stop=False)
            self.stop_listening = None

    def _callback(self, recognizer, audio):
        try:
            text = recognizer.recognize_google(audio)
            text = text.lower().strip()
            print("Voice heard:", text)
            cmd = self._parse_command(text)
            if cmd:
                self.command_queue.put(cmd)
        except sr.UnknownValueError:
            pass
        except sr.RequestError as e:
            print("VoiceController: API error:", e)

    def _parse_command(self, text):
        if any(kw in text for kw in ("forward", "go forward", "move forward")):
            return ("forward", None)
        if any(kw in text for kw in ("back", "backward", "go back", "move back")):
            return ("backward", None)
        if any(kw in text for kw in ("left", "turn left", "go left")):
            return ("left", None)
        if any(kw in text for kw in ("right", "turn right", "go right")):
            return ("right", None)
        if "stop" in text or "halt" in text:
            return ("stop", None)
        if "autonomous on" in text or "autonomy on" in text or "autonomous mode" in text:
            return ("autonomous_on", None)
        if "autonomous off" in text or "autonomy off" in text:
            return ("autonomous_off", None)
        if "speed" in text:
            words = text.split()
            for w in words:
                if w.isdigit():
                    val = int(w)
                    return ("speed", val)
        return None

# --- IR controller using python-lirc (non-blocking polling) ---
class IRController:
    def __init__(self, command_queue, lirc_socket_name="robot"):
        self.command_queue = command_queue
        self.lirc_socket_name = lirc_socket_name
        self.client = None
        if LIRC_AVAILABLE:
            try:
                # initialize lirc client; requires system LIRC configured
                self.client = lirc.Client(self.lirc_socket_name)
            except Exception:
                # older python-lirc uses lirc.init / lirc.nextcode; handle fallback
                try:
                    lirc.init(self.lirc_socket_name, blocking=False)
                    self.client = None
                except Exception:
                    self.client = None
        else:
            self.client = None

    def poll(self):
        """
        Non-blocking poll for IR codes. Returns list of decoded key names or empty list.
        Works with both python-lirc Client and legacy lirc.nextcode.
        """
        if not LIRC_AVAILABLE:
            return []
        try:
            # modern python-lirc: client.next()
            if hasattr(self, "client") and self.client:
                codes = self.client.next(timeout=0)
                # client.next returns list-like or raises; normalize
                if not codes:
                    return []
                return codes
            # fallback to legacy API
            codes = lirc.nextcode()
            return codes or []
        except Exception:
            return []

    def parse_ir_key(self, key):
        """
        Map IR key names (from LIRC config) to command tuples.
        Adjust mapping to match your remote's key names in LIRC config.
        """
        k = key.lower()
        # common LIRC key names mapping
        if any(x in k for x in ("up", "vol+", "volumeup", "volume_up")):
            return ("forward", None)
        if any(x in k for x in ("down", "vol-", "volumedown", "volume_down")):
            return ("backward", None)
        if any(x in k for x in ("left", "rewind", "prev")):
            return ("left", None)
        if any(x in k for x in ("right", "forward", "next")):
            return ("right", None)
        if any(x in k for x in ("play", "pause", "ok", "enter")):
            return ("stop", None)
        if "power" in k:
            return ("stop", None)
        if "autonomous" in k or "mode" in k:
            return ("autonomous_on", None)
        # numeric speed shortcuts: e.g., KEY_1 -> speed 20, KEY_2 -> 40, etc.
        if k.startswith("key_") and k[4:].isdigit():
            n = int(k[4:])
            # map 0-9 to speed 0-100
            val = max(0, min(100, int(n * 11)))
            return ("speed", val)
        # direct digits
        if k.isdigit():
            n = int(k)
            val = max(0, min(100, int(n * 11)))
            return ("speed", val)
        return None

# --- Main loop ---
def main(mic_device_index=None):
    setup_motors()
    kr = KeyReader()
    speed = DEFAULT_SPEED
    autonomous = False

    cam = cv2.VideoCapture(0)
    voice_queue = queue.Queue()
    ir_queue = queue.Queue()

    vc = VoiceController(voice_queue, mic_device_index=mic_device_index)
    vc.start()

    irc = IRController(ir_queue)
    if not LIRC_AVAILABLE:
        print("IR: python-lirc not available; IR input disabled. Install python-lirc and configure LIRC to enable IR.")
    else:
        print("IR: LIRC available; ensure LIRC is configured for your remote and GPIO 17.")

    print("Hold W/A/S/D to move manually")
    print("Press O = autonomous mode ON")
    print("Press Q = quit program")
    if VOICE_AVAILABLE:
        print("Voice control enabled.")
    else:
        print("Voice control not available (SpeechRecognition/PyAudio missing).")
    print("IR control: listening on LIRC (GPIO 17).")

    try:
        while True:
            key = kr.get_key()
            if key:
                key = key.lower()
                if key == "q":
                    break
                if key == "o":
                    autonomous = True
                    print("Autonomous mode enabled")
                if key in ("w", "a", "s", "d"):
                    autonomous = False
                if not autonomous:
                    if key == "w":
                        forward(speed)
                    elif key == "s":
                        backward(speed)
                    elif key == "a":
                        turn_left(speed)
                    elif key == "d":
                        turn_right(speed)

            # process voice commands (non-blocking)
            try:
                while True:
                    cmd_tuple = voice_queue.get_nowait()
                    if not cmd_tuple:
                        continue
                    cmd, val = cmd_tuple
                    if cmd == "forward":
                        autonomous = False
                        forward(speed)
                        print("Voice command: forward")
                    elif cmd == "backward":
                        autonomous = False
                        backward(speed)
                        print("Voice command: backward")
                    elif cmd == "left":
                        autonomous = False
                        turn_left(speed)
                        print("Voice command: left")
                    elif cmd == "right":
                        autonomous = False
                        turn_right(speed)
                        print("Voice command: right")
                    elif cmd == "stop":
                        autonomous = False
                        stop_all()
                        print("Voice command: stop")
                    elif cmd == "autonomous_on":
                        autonomous = True
                        print("Voice command: autonomous on")
                    elif cmd == "autonomous_off":
                        autonomous = False
                        print("Voice command: autonomous off")
                    elif cmd == "speed" and isinstance(val, int):
                        speed = max(0, min(100, val))
                        set_speed(speed)
                        print(f"Voice command: set speed to {speed}")
            except queue.Empty:
                pass

            # poll IR (non-blocking)
            if LIRC_AVAILABLE:
                codes = irc.poll()
                for code in codes:
                    # code may be a string or list; normalize
                    if isinstance(code, (list, tuple)):
                        for c in code:
                            parsed = irc.parse_ir_key(c)
                            if parsed:
                                ir_queue.put(parsed)
                    else:
                        parsed = irc.parse_ir_key(code)
                        if parsed:
                            ir_queue.put(parsed)

            # process IR commands
            try:
                while True:
                    cmd_tuple = ir_queue.get_nowait()
                    if not cmd_tuple:
                        continue
                    cmd, val = cmd_tuple
                    if cmd == "forward":
                        autonomous = False
                        forward(speed)
                        print("IR command: forward")
                    elif cmd == "backward":
                        autonomous = False
                        backward(speed)
                        print("IR command: backward")
                    elif cmd == "left":
                        autonomous = False
                        turn_left(speed)
                        print("IR command: left")
                    elif cmd == "right":
                        autonomous = False
                        turn_right(speed)
                        print("IR command: right")
                    elif cmd == "stop":
                        autonomous = False
                        stop_all()
                        print("IR command: stop")
                    elif cmd == "autonomous_on":
                        autonomous = True
                        print("IR command: autonomous on")
                    elif cmd == "autonomous_off":
                        autonomous = False
                        print("IR command: autonomous off")
                    elif cmd == "speed" and isinstance(val, int):
                        speed = max(0, min(100, val))
                        set_speed(speed)
                        print(f"IR command: set speed to {speed}")
            except queue.Empty:
                pass

            if autonomous:
                ret, frame = cam.read()
                if not ret:
                    stop_all()
                    continue
                state = detect_obstacle(frame)
                if state == "clear":
                    forward(speed)
                elif state == "left":
                    turn_right(speed)
                elif state == "right":
                    turn_left(speed)
                elif state == "center":
                    turn_left(speed)

            if not key and not autonomous:
                stop_all()

            time.sleep(0.02)

    finally:
        vc.stop()
        # if legacy lirc was initialized, try to deinit
        try:
            if LIRC_AVAILABLE and hasattr(lirc, "deinit"):
                lirc.deinit()
        except Exception:
            pass
        cam.release()
        cleanup()

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Robot control (keyboard, camera autonomy, optional voice, IR).")
    parser.add_argument("--mic", type=int, default=None, help="Microphone device index (if USB mic is not default).")
    args = parser.parse_args()
    main(mic_device_index=args.mic)
